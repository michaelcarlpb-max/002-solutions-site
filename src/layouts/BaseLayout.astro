---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { renderJsonLd } from '../lib/schema';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Additional schema.org entities to merge into the page's @graph. Single object or array. */
  schema?: unknown | unknown[];
}

const {
  title,
  description = 'Freelance IT consulting, iOS development, and AI automation — based in Tampa, Florida. Remote-friendly.',
  ogImage = '/og.png',
  schema,
} = Astro.props;

const pageSchemas = schema === undefined ? [] : Array.isArray(schema) ? schema : [schema];
const jsonLd = renderJsonLd(pageSchemas);

const siteName = '002 Solutions';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://002solutions.com').toString();
const fullTitle = title === siteName ? `${siteName} — Practical technology consulting` : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="002 Solutions — Writing" href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://002solutions.com').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="002 Solutions — Practical technology, built by someone who actually ships." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://002solutions.com').toString()} />
    <meta name="twitter:image:alt" content="002 Solutions — Practical technology, built by someone who actually ships." />

    <meta name="theme-color" content="#0A0E1A" />

    <script type="application/ld+json" set:html={jsonLd} is:inline />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
