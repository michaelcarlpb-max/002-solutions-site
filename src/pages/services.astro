---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="Services"
  description="Freelance IT consulting, iOS development, AI automation, and general technology advisory — delivered by Michael Carl at 002 Solutions."
>
  <section class="container-site pt-20 sm:pt-28 pb-10">
    <SectionHeading
      eyebrow="// SERVICES"
      title="Four ways I can help."
      subtitle="Scoped engagements, clear pricing, and senior-level work delivered end-to-end."
    />
  </section>

  <section class="reveal container-site pb-20 sm:pb-28">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {services.map((s) => (
        <ServiceCard
          title={s.title}
          description={s.summary}
          icon={s.icon}
          bullets={s.deliverables.slice(0, 4)}
          href={`/services/${s.slug}`}
        />
      ))}
    </div>
  </section>

  <section class="reveal container-site pb-20 sm:pb-28 border-t hairline pt-20">
    <div class="text-center max-w-2xl mx-auto">
      <p class="eyebrow mb-4">// NEXT STEP</p>
      <h2 class="text-3xl sm:text-4xl font-bold">Not sure which one fits?</h2>
      <p class="mt-4 text-lg text-fog-2 leading-relaxed">
        Describe your situation in a few sentences. I'll tell you whether I can help, and if not, who might.
      </p>
      <div class="mt-8">
        <a href="/contact" class="btn-primary">
          Get in touch
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
