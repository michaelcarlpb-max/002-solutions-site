---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Michael Carl at 002 Solutions — describe your project and I'll reply within a couple of business days."
>
  <section class="container-site pt-20 sm:pt-28 pb-20">
    <p class="eyebrow mb-6">// CONTACT</p>
    <h1 class="text-4xl sm:text-5xl font-bold">Let's talk.</h1>
    <p class="mt-4 text-lg text-fog-2 max-w-2xl leading-relaxed">
      Tell me a bit about what you're working on. I'll get back to you within a couple of business days.
    </p>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14">
      <div class="lg:col-span-2">
        <ContactForm />
      </div>

      <aside class="lg:col-span-1 space-y-6">
        <div class="rounded-lg border hairline bg-ink-2/40 p-6">
          <p class="eyebrow mb-5">// WHAT TO EXPECT</p>
          <dl class="space-y-5">
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Response time</dt>
              <dd class="mt-1.5 text-fog leading-relaxed">
                Within a couple of business days, typically the same day.
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Typical engagement</dt>
              <dd class="mt-1.5 text-fog leading-relaxed">
                2–8 weeks, fixed scope, fixed price. Longer on larger builds.
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Great fit for</dt>
              <dd class="mt-2">
                <ul class="space-y-1.5 text-sm text-fog">
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-yellow flex-shrink-0" aria-hidden="true"></span>
                    <span>Small businesses and founders</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-yellow flex-shrink-0" aria-hidden="true"></span>
                    <span>Shipping an iOS app end-to-end</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-yellow flex-shrink-0" aria-hidden="true"></span>
                    <span>Putting AI to work on a real problem</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-yellow flex-shrink-0" aria-hidden="true"></span>
                    <span>A second pair of eyes on your stack</span>
                  </li>
                </ul>
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Probably not a fit</dt>
              <dd class="mt-2">
                <ul class="space-y-1.5 text-sm text-fog-2">
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-fog-2/40 flex-shrink-0" aria-hidden="true"></span>
                    <span>Urgent same-day emergencies</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-fog-2/40 flex-shrink-0" aria-hidden="true"></span>
                    <span>Staff augmentation or long retainers</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-fog-2/40 flex-shrink-0" aria-hidden="true"></span>
                    <span>Enterprise RFPs or procurement flows</span>
                  </li>
                </ul>
              </dd>
            </div>
          </dl>
        </div>

        <div class="rounded-lg border hairline bg-ink-2/40 p-6">
          <p class="eyebrow mb-4">// OTHER WAYS TO REACH ME</p>
          <dl class="space-y-4">
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Email</dt>
              <dd class="mt-1">
                <a
                  href="mailto:michael.carlpb@gmail.com"
                  class="text-white hover:text-brand-yellow break-all transition"
                >
                  michael.carlpb@gmail.com
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Based in</dt>
              <dd class="mt-1 text-fog">Tampa, Florida · Eastern Time</dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-fog-2">Availability</dt>
              <dd class="mt-1 text-fog">Remote worldwide</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
