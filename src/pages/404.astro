---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist — or has moved."
>
  <section class="container-site py-32 sm:py-40 min-h-[70vh] flex items-center">
    <div class="max-w-2xl">
      <p class="eyebrow mb-6">// ERROR 404</p>
      <div class="font-display text-7xl sm:text-8xl font-bold leading-none bg-brand-gradient bg-clip-text text-transparent">
        404
      </div>
      <h1 class="mt-8 text-4xl sm:text-5xl font-bold leading-tight">
        This page <span class="bg-brand-gradient bg-clip-text text-transparent">doesn't exist</span>.
      </h1>
      <p class="mt-5 text-lg text-fog-2 leading-relaxed">
        The link might be broken, or the page may have moved. Let's get you back on track.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/" class="btn-primary">
          Back to home
          <span aria-hidden="true">→</span>
        </a>
        <a href="/contact" class="btn-secondary">
          Get in touch
        </a>
      </div>

      <div class="mt-14 pt-10 border-t hairline">
        <p class="eyebrow mb-5">// OR TRY</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-lg">
          <li>
            <a href="/services" class="group flex items-center justify-between rounded-lg border hairline bg-ink-2/40 p-4 transition hover:border-white/25 hover:bg-ink-2/70">
              <span class="font-medium">Services</span>
              <span class="text-brand-yellow group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a href="/about" class="group flex items-center justify-between rounded-lg border hairline bg-ink-2/40 p-4 transition hover:border-white/25 hover:bg-ink-2/70">
              <span class="font-medium">About</span>
              <span class="text-brand-yellow group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
