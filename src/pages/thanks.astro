---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thanks"
  description="Message received — I'll be in touch soon."
>
  <section class="container-site py-32 sm:py-40 min-h-[60vh] flex items-center">
    <div class="max-w-xl">
      <p class="eyebrow mb-6">// MESSAGE RECEIVED</p>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight">
        Thanks — I'll be <span class="bg-brand-gradient bg-clip-text text-transparent">in touch soon</span>.
      </h1>
      <p class="mt-5 text-lg text-fog-2 leading-relaxed">
        Your message is on its way. I typically reply within a couple of business days.
      </p>
      <div class="mt-10">
        <a href="/" class="btn-secondary">
          <span aria-hidden="true">←</span>
          Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
