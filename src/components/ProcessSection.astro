---
import SectionHeading from './SectionHeading.astro';

const steps = [
  {
    number: '01',
    title: 'Scope',
    description:
      "A short call to understand what you're building and where you're stuck. If I'm not the right fit, I'll tell you — and suggest someone who might be.",
  },
  {
    number: '02',
    title: 'Proposal',
    description:
      'A written scope with concrete deliverables, a realistic timeline, and a fixed price. You approve the plan before anything starts.',
  },
  {
    number: '03',
    title: 'Build & ship',
    description:
      "I do the work. You get weekly updates and direct access the whole way — no account managers, no handoffs, no status-meeting theater.",
  },
];
---

<section class="reveal container-site py-20 sm:py-28 border-t hairline">
  <SectionHeading
    eyebrow="// 02 — HOW I WORK"
    title="What hiring me looks like."
    subtitle="Short engagements, clear scope, direct access. No discovery calls that turn into sales pitches."
  />

  <ol class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    {steps.map((step) => (
      <li class="group relative rounded-lg border hairline bg-ink-2/30 p-7 sm:p-8 transition-all duration-300 hover:border-white/20 hover:bg-ink-2/50">
        <div class="font-display text-6xl font-bold leading-none bg-brand-gradient bg-clip-text text-transparent">
          {step.number}
        </div>
        <h3 class="mt-6 text-xl font-semibold">{step.title}</h3>
        <div class="mt-4 h-px w-10 bg-brand-yellow/50"></div>
        <p class="mt-5 text-fog-2 leading-relaxed">{step.description}</p>
      </li>
    ))}
  </ol>
</section>
