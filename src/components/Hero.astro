---
// Hero for the home page.
---

<section class="relative overflow-hidden border-b hairline">
  <div class="absolute inset-0 hero-grid hero-grid-animated opacity-60" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-ink/40 to-ink pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute -top-24 -right-24 w-[480px] h-[480px] rounded-full blur-3xl opacity-20 bg-brand-gradient pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-site relative py-24 sm:py-32 lg:py-40">
    <p class="eyebrow mb-6">// 002 SOLUTIONS</p>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] max-w-4xl">
      Practical technology, built by someone who actually
      <span class="bg-brand-gradient bg-clip-text text-transparent">ships</span>.
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-fog-2 max-w-2xl leading-relaxed">
      Freelance consulting across iOS, AI automation, and general tech advisory — based in Tampa, Florida. Remote-friendly.
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a href="/contact" class="btn-primary">
        Start a conversation
        <span aria-hidden="true">→</span>
      </a>
      <a href="/services" class="btn-secondary">See services</a>
    </div>
  </div>
</section>
