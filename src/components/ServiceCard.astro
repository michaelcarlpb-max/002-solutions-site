---
interface Props {
  title: string;
  description: string;
  href?: string;
  icon?: 'consulting' | 'ios' | 'ai' | 'advisory';
  bullets?: string[];
}

const { title, description, href, icon, bullets } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group relative block rounded-lg border hairline bg-ink-2/40 p-6 sm:p-8 transition',
    href && 'hover:border-white/30 hover:bg-ink-2/70',
  ]}
>
  {icon && (
    <div class="mb-5 inline-flex items-center justify-center w-11 h-11 rounded-md border hairline bg-ink text-brand-yellow">
      {icon === 'consulting' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="14" rx="2" />
          <path d="M8 20h8" />
          <path d="M12 18v2" />
          <path d="M7 10h4" />
          <path d="M7 14h7" />
        </svg>
      )}
      {icon === 'ios' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="6" y="2" width="12" height="20" rx="2.5" />
          <path d="M11 18h2" />
        </svg>
      )}
      {icon === 'ai' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2v3" />
          <path d="M12 19v3" />
          <path d="M4.22 4.22l2.12 2.12" />
          <path d="M17.66 17.66l2.12 2.12" />
          <path d="M2 12h3" />
          <path d="M19 12h3" />
          <circle cx="12" cy="12" r="5" />
        </svg>
      )}
      {icon === 'advisory' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <circle cx="12" cy="12" r="3" />
        </svg>
      )}
    </div>
  )}
  <h3 class="text-xl font-semibold">{title}</h3>
  <p class="mt-3 text-fog-2 leading-relaxed">{description}</p>
  {bullets && bullets.length > 0 && (
    <ul class="mt-5 space-y-2">
      {bullets.map((b) => (
        <li class="flex items-start gap-3 text-sm text-fog">
          <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-brand-yellow flex-shrink-0" aria-hidden="true"></span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  )}
  {href && (
    <span class="mt-6 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-brand-yellow group-hover:gap-2 transition-all">
      Learn more <span aria-hidden="true">→</span>
    </span>
  )}
</Tag>
